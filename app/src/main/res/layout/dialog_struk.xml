<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="HUSNA OLI"
        android:textAlignment="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Jl. Raya Husna No. 123"
        android:textAlignment="center"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_struk_tanggal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tanggal: 01-01-2024"
        android:textSize="12sp"
        android:layout_marginTop="10dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#000000"
        android:layout_marginVertical="8dp" />

    <LinearLayout
        android:id="@+id/ll_struk_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#000000"
        android:layout_marginVertical="8dp" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TableRow android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="TOTAL"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_struk_total"
                android:layout_width="wrap_content"
                android:text="Rp 0"
                android:textStyle="bold" />
        </TableRow>

        <TableRow android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="BAYAR" />
            <TextView
                android:id="@+id/tv_struk_bayar"
                android:layout_width="wrap_content"
                android:text="Rp 0" />
        </TableRow>

        <TableRow>
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="KEMBALI" />
            <TextView
                android:id="@+id/tv_struk_kembali"
                android:layout_width="wrap_content"
                android:text="Rp 0" />
        </TableRow>
    </TableLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Terima Kasih Atas Kunjungan Anda"
        android:textAlignment="center"
        android:textSize="12sp"
        android:layout_marginTop="20dp"
        android:textStyle="italic" />

    <Button
        android:id="@+id/btn_tutup_struk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tutup"
        android:layout_marginTop="15dp"
        android:backgroundTint="@color/orange_accent" />

</LinearLayout>
